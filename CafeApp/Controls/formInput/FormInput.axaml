<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CafeApp.Controls.FormInput"
             xmlns:button="clr-namespace:CafeApp.Controls.Components.Button"
             xmlns:combobox="clr-namespace:CafeApp.Controls.Components.ComboBox"
             xmlns:input="clr-namespace:CafeApp.Controls.Components.Input"
             Width="400"
             x:Name="root">
    
    <UserControl.Styles>
        <!-- Стили для полей ввода -->
        
    </UserControl.Styles>

    <StackPanel Spacing="15">
        <TextBlock x:Name="TitleTextBlock" Text="{Binding #root.Title}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#194E84"
                   HorizontalAlignment="Center"/>
        
        <!-- ComboBox будет скрываться при Title = "Авторизация" -->
        <combobox:ComboBox Text="Роль:" 
                          IsVisible="{Binding #root.ShowRoleSelector}"/>

        <StackPanel Spacing="5">
            <input:Input Text="Логин" />
            <input:Input Text="Пароль" IsPassword="True"/>

        </StackPanel>

        <button:Button Text="Далее"
                       HorizontalAlignment="Stretch"/>
    </StackPanel>
</UserControl>