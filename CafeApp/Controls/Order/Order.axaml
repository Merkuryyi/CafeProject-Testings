<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:combobox="clr-namespace:CafeApp.Controls.Components.ComboBox"
             xmlns:input="clr-namespace:CafeApp.Controls.Components.Input"
             xmlns:controls="clr-namespace:CafeApp.Controls"
             xmlns:button="clr-namespace:CafeApp.Controls.Components.Button"
             x:Class="CafeApp.Controls.Order"
             x:Name="root"
             x:DataType="controls:Order">
    
    <StackPanel >
        <Border Padding="15,15,15,0">
            <StackPanel Spacing="5" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding #root.Title}" x:Name="OrderTitleTextBlock"
                           FontSize="20" 
                           Foreground="#194E84"
                           FontWeight="Bold"  Margin="0,0,25,25"/>
                    <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0} руб.'}" 
                               x:Name="PriceTextBlock"
                               FontSize="20" 
                               Foreground="#194E84"
                               FontWeight="Bold"  
                               Margin="0,0,0,25"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <combobox:ComboBox x:Name="StatusComboBox" 
                           Text="Статус" 
                           ComboBoxWidth="100"
                           Margin="0,0,10,0"
                           ItemsSource="{Binding StatusOrder}" IsVisible="True"/>  
                    <StackPanel  x:Name="StatusPanel" IsVisible="False">
                        <TextBlock Text="Статус"
                                   FontSize="14"
                                   Margin="0,0,10,0"
                                   Foreground="#194E84" />
                        <TextBlock x:Name="StatusTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Margin="0,0,25,0"
                                   Foreground="#194E84"/>
                    </StackPanel>
                    <combobox:ComboBox x:Name="WaiterComboBox" 
                               Text="Официант" 
                               Margin="0,0,10,0"
                               ComboBoxWidth="150"
                               ItemsSource="{Binding ListWaiter}" IsVisible="True"/> 
                    <StackPanel x:Name="WaiterPanel" IsVisible="False">
                        <TextBlock Text="Официант"
                                   FontSize="14"
                                   Margin="0,0,10,10"
                                   Foreground="#194E84" />
                        <TextBlock x:Name="WaiterTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Margin="0,0,10,0"
                                   Foreground="#194E84"/>
                    </StackPanel>
                    <input:Input x:Name="TableInput" Text="Столик" InputWidth="50" 
                                 IsVisible="True"  Margin="0,0,10,0"/>
                    <input:Input x:Name="CustomerCountInput" Text="Кол. гостей" 
                                 InputWidth="50" IsVisible="True"  Margin="0,0,10,0"/>
                    
                    <StackPanel Spacing="5" x:Name="TablePanel" IsVisible="False" Margin="0,0,10,0">
                        <TextBlock Text="Столик" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="TableTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84" />
                        
                    </StackPanel>
                    <StackPanel Spacing="5" x:Name="CustomerCountPanel" IsVisible="False" >
                        <TextBlock Text="Кол. гостей" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="CustomerCountTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84" />
                        
                    </StackPanel>
                </StackPanel>
                <StackPanel >
                    <combobox:ComboBox x:Name="PaymentSelectionComboBox" 
                           Text="Оплата"  HorizontalAlignment="Left"
                           ComboBoxWidth="200"
                           ItemsSource="{Binding PaymentSelection}" IsVisible="False"/> 
                    <StackPanel  x:Name="PaymentPanel" IsVisible="False">
                        <TextBlock Text="Вариант оплаты"
                                   FontSize="14"
                                   Margin="0,0,25,0"
                                   Foreground="#194E84" />
                        <TextBlock x:Name="PaymentTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Margin="0,0,25,0"
                                   Foreground="#194E84"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
             
        </Border>
        
        <Border Padding="15,15,15,0">
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="Меню"
                               FontSize="20"
                               Foreground="#194E84"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="AddMenuItemButton"
                               Text="+"
                               FontSize="20" 
                               Cursor="Hand"
                               Foreground="#194E84" IsVisible="True"/>
                    <TextBlock x:Name="RemoveMenuItemButton"
                               Text="-"
                               FontSize="20" 
                               Cursor="Hand"
                               Foreground="#194E84"/>
                </StackPanel>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180" x:Name="MenuScrollViewer" >
                    <ItemsControl x:Name="MenuItemsControl" ItemsSource="{Binding OrderMenuItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel x:Name="MenuItemStackPanel" 
                                            Orientation="Horizontal" 
                                            Spacing="10" 
                                            HorizontalAlignment="Left" 
                                            Margin="0,10,0,0">
                                    <combobox:ComboBox x:Name="MenuItemComboBox"
                                                       Text="Название" 
                                                       ComboBoxWidth="100"
                                                       ItemsSource="{Binding #root.AllMenuItems}"
                                                       SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}">
                                        <combobox:ComboBox.Styles>
                                            <Style Selector="ComboBox">
                                                <Setter Property="SelectedItem" 
                                                        Value="{Binding SelectedMenuItem, Mode=TwoWay}"/>
                                            </Style>
                                        </combobox:ComboBox.Styles>
                                    </combobox:ComboBox>
                    
                                    <input:Input x:Name="QuantityInput" 
                                                 Text="Кол." 
                                                 InputWidth="150"
                                                 Value="{Binding Quantity, Mode=TwoWay}">
                                        <input:Input.Styles>
                                            <Style Selector="TextBox">
                                                <Setter Property="Text" Value="{Binding Quantity, Mode=TwoWay}"/>
                                            </Style>
                                        </input:Input.Styles>
                                    </input:Input>  
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200" x:Name="MenuScrollViewerFalse" IsVisible="False">
                    <ItemsControl x:Name="MenuItemsControlFalse" ItemsSource="{Binding OrderMenuItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel x:Name="MenuItemStackPanel" 
                                            Orientation="Horizontal" 
                                            Spacing="25" 
                                            HorizontalAlignment="Left" 
                                            Margin="0,10,0,0">
                                    <StackPanel Spacing="5" x:Name="MenuItemNamePanel" >
                                        <TextBlock Text="Название" 
                                                   FontSize="14"
                                                   Foreground="#194E84"/>
                                        <TextBlock x:Name="NameMenuItem"
                                                   Text="{Binding SelectedMenuItem}" 
                                                   FontSize="14"
                                                   Foreground="#194E84" />
                                    </StackPanel>
                                    <StackPanel Spacing="5" x:Name="MenuItemQuantityPanel" >
                                        <TextBlock Text="Количество" 
                                                   FontSize="14"
                                                   Foreground="#194E84"/>
                                        <TextBlock x:Name="QuantityMenuItem"
                                                   Text="{Binding Quantity}" 
                                                   FontSize="14"
                                                   Foreground="#194E84" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <button:Button x:Name="SaveButton" Text="Сохранить"
                               HorizontalAlignment="Stretch"  Click="SaveButton_Click"/> 
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>