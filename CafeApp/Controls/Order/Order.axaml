<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:combobox="clr-namespace:CafeApp.Controls.Components.ComboBox"
             xmlns:input="clr-namespace:CafeApp.Controls.Components.Input"
             xmlns:controls="clr-namespace:CafeApp.Controls"
             xmlns:button="clr-namespace:CafeApp.Controls.Components.Button"
             x:Class="CafeApp.Controls.Order"
             x:Name="root"
             x:DataType="controls:Order">
    
    <StackPanel Spacing="30">
        <Border Padding="15">
            <StackPanel Spacing="15">
                <TextBlock Text="{Binding #root.Title}" x:Name="OrderTitleTextBlock"
                           FontSize="20" 
                           Foreground="#194E84"
                           FontWeight="Bold"/>
                
                <StackPanel Orientation="Horizontal" Spacing="25" HorizontalAlignment="Left">
                    <combobox:ComboBox x:Name="StatusComboBox" 
                               Text="Статус" 
                               ComboBoxWidth="200"
                               ItemsSource="{Binding StatusOrder}" IsVisible="True"/>  
                    <combobox:ComboBox x:Name="WaiterComboBox" 
                               Text="Официант" 
                               ComboBoxWidth="160"
                               ItemsSource="{Binding ListWaiter}" IsVisible="True"/> 
                    <input:Input x:Name="TableInput" Text="Столик" InputWidth="50" IsVisible="True"/>
                    <StackPanel Spacing="5" x:Name="WaiterPanel" IsVisible="False">
                        <TextBlock Text="Официант"
                                   FontSize="14"
                                   Foreground="#194E84" />
                        <TextBlock x:Name="WaiterTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84"/>
                    </StackPanel>
                    <StackPanel Spacing="5" x:Name="TablePanel" IsVisible="False" >
                        <TextBlock Text="Столик" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="TableTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Padding="15">
            <StackPanel Spacing="15">
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="Меню"
                               FontSize="20"
                               Foreground="#194E84"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="AddMenuItemButton"
                               Text="+"
                               FontSize="20" 
                               Cursor="Hand"
                               Foreground="#194E84" IsVisible="True"/>
                    <TextBlock x:Name="RemoveMenuItemButton"
                               Text="-"
                               FontSize="20" 
                               Cursor="Hand"
                               Foreground="#194E84"/>
                </StackPanel>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200" x:Name="MenuScrollViewer" >
                    <ItemsControl x:Name="MenuItemsControl" ItemsSource="{Binding OrderMenuItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel x:Name="MenuItemStackPanel" 
                                            Orientation="Horizontal" 
                                            Spacing="25" 
                                            HorizontalAlignment="Left" 
                                            Margin="0,10,0,0">
                                    <combobox:ComboBox x:Name="MenuItemComboBox"
                                        Text="Название" 
                                        ComboBoxWidth="200"
                                        ItemsSource="{Binding #root.AllMenuItems}"
                                        SelectedItem="{Binding SelectedMenuItem}"/>  
                                    
                                    <input:Input x:Name="QuantityInput" 
                                        Text="Кол." 
                                        InputWidth="160"
                                        Value="{Binding Quantity}"/>  
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200" x:Name="MenuScrollViewerFalse" IsVisible="False">
                    <ItemsControl x:Name="MenuItemsControlFalse" ItemsSource="{Binding OrderMenuItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel x:Name="MenuItemStackPanel" 
                                            Orientation="Horizontal" 
                                            Spacing="25" 
                                            HorizontalAlignment="Left" 
                                            Margin="0,10,0,0">
                                    <StackPanel Spacing="5" x:Name="MenuItemNamePanel" >
                                        <TextBlock Text="Название" 
                                                   FontSize="14"
                                                   Foreground="#194E84"/>
                                        <TextBlock x:Name="NameMenuItem"
                                                   Text="{Binding SelectedMenuItem}" 
                                                   FontSize="14"
                                                   Foreground="#194E84" />
                                    </StackPanel>
                                    <StackPanel Spacing="5" x:Name="MenuItemQuantityPanel" >
                                        <TextBlock Text="Количество" 
                                                   FontSize="14"
                                                   Foreground="#194E84"/>
                                        <TextBlock x:Name="QuantityMenuItem"
                                                   Text="{Binding Quantity}" 
                                                   FontSize="14"
                                                   Foreground="#194E84" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <button:Button x:Name="SaveButton" Text="Сохранить"
                               HorizontalAlignment="Stretch"  Click="SaveButton_Click"/> 
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>