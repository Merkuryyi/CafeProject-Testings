<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:button="clr-namespace:CafeApp.Controls.Components.Button"
             xmlns:combobox="clr-namespace:CafeApp.Controls.Components.ComboBox"
             xmlns:input="clr-namespace:CafeApp.Controls.Components.Input"
             xmlns:draganddrop="clr-namespace:CafeApp.Controls.Components.DragAndDrop"
             xmlns:local="clr-namespace:CafeApp.Controls"
             x:Class="CafeApp.Controls.FormEmployee"
             x:Name="root"  		
             x:DataType="local:FormEmployee">
    
    <Grid>
        <StackPanel Spacing="15" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="{Binding #root.Title}" x:Name="EmployeeTitleTextBlock"
                       FontSize="20" 
                       Foreground="#194E84"
                       FontWeight="Bold"  Margin="0,0,25,25"/>
            <StackPanel Orientation="Horizontal" Spacing="50" HorizontalAlignment="Center" Margin="0,10,0,0">
              
                <StackPanel Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left"  Margin="0,0,0,20">
                        <TextBlock Text="Фото сотрудника" 
                            FontSize="20"
                            FontWeight="Normal"
                            Foreground="#194E84" />
                        <TextBlock Text="+" x:Name="AddPhotoEmployee"
                            FontSize="20"
                            FontWeight="Normal"
                            Foreground="#194E84"
                            Cursor="Hand" />
                    </StackPanel>
             
                    <input:Input x:Name="UsernameInput" Text="Логин" InputWidth="200"/>
                    <input:Input x:Name="PasswordInput" Text="Пароль" IsPassword="True" InputWidth="200"/>
                    <combobox:ComboBox x:Name="RoleComboBox" 
                       Text="Роль" 
                       ComboBoxWidth="200"
                       Margin="0,0,0,20"
                       ItemsSource="{Binding Roles}"/>  
                    <combobox:ComboBox x:Name="StatusComboBox" 
                                       Text="Роль" 
                                       ComboBoxWidth="200"
                                       Margin="0,0,0,20"
                                       ItemsSource="{Binding Status}"/>  
                    <StackPanel  x:Name="LoginPanel" IsVisible="False">
                        <TextBlock Text="Логин" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="LoginTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84" />
                    </StackPanel>
                    <StackPanel  x:Name="PasswordPanel" IsVisible="False">
                        <TextBlock Text="Логин" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="PasswordTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84" />
                    </StackPanel>
                    <StackPanel  x:Name="RolePanel" IsVisible="False">
                        <TextBlock Text="Логин" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="RoleTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84" />
                    </StackPanel>
                </StackPanel>

            
                <StackPanel Spacing="5">
     
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left"  Margin="0,0,0,20">
                        <TextBlock Text="Трудовой договор"
                            FontSize="20"
                            FontWeight="Normal"
                            Foreground="#194E84"/>
                        <TextBlock Text="+" x:Name="AddEmploymentContract"
                            FontSize="20"
                            FontWeight="Normal"
                            Foreground="#194E84"/>
                    </StackPanel>
                    
              
                    <input:Input x:Name="NameInput" Text="Фамилия" InputWidth="200"/>
                    <input:Input x:Name="SurnameInput" Text="Имя" InputWidth="200"/>
                    <input:Input x:Name="PatronymicInput" Text="Отчество" InputWidth="200"/>
                    <StackPanel  x:Name="NamePanel" IsVisible="False">
                        <TextBlock Text="Логин" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="NameTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84" />
                    </StackPanel>
                    <StackPanel  x:Name="SurnamePanel" IsVisible="False">
                        <TextBlock Text="Логин" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="SurnameTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84" />
                    </StackPanel>
                    <StackPanel  x:Name="PatronymicPanel" IsVisible="False">
                        <TextBlock Text="Логин" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="PatronymicTextBlock"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#194E84" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            
            <button:Button x:Name="SaveButton" Text="Сохранить"
                HorizontalAlignment="Stretch" Click="SaveButton_Click"/> 
        </StackPanel>


        <draganddrop:DragAndDrop x:Name="DragAndDrop" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center" 
            IsVisible="False" />
    </Grid>
</UserControl>