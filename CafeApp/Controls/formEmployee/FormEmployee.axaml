<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:button="clr-namespace:CafeApp.Controls.Components.Button"
             xmlns:combobox="clr-namespace:CafeApp.Controls.Components.ComboBox"
             xmlns:input="clr-namespace:CafeApp.Controls.Components.Input"
             xmlns:local="clr-namespace:CafeApp.Controls"
             x:Class="CafeApp.Controls.FormEmployee"
             x:Name="root"  		
             x:DataType="local:FormEmployee">
    
    <StackPanel Spacing="15">

        <!-- Горизонтальная панель для двух колонок -->
        <StackPanel Orientation="Horizontal" Spacing="50" HorizontalAlignment="Center" Margin="0,10,0,0">
            
            <!-- Левая колонка: Фото + Логин + Пароль -->
            <StackPanel Spacing="5">
                <!-- Фото сотрудника и + в одной строке -->
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left"  Margin="0,0,0,20">
                    <TextBlock Text="Фото сотрудника"
                               FontSize="20"
                               FontWeight="Normal"
                               Foreground="#194E84" />
                    <TextBlock Text="+"
                               FontSize="20"
                               FontWeight="Normal"
                               Foreground="#194E84"/>
                    <Path Data="M21 15V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V15 M7 10L12 15L17 10 M12 15V3" 
                          Stroke="#194E84" 
                          StrokeThickness="2"
                          Width="12" 
                          Height="12"
                          Stretch="Uniform" Cursor="Hand"/>
                </StackPanel>
                
                <!-- Поля под фото -->
                <input:Input x:Name="UsernameInput" Text="Логин" InputWidth="200"/>
                <input:Input x:Name="PasswordInput" Text="Пароль" IsPassword="True" InputWidth="200"/>
                <combobox:ComboBox x:Name="RoleComboBox" 
                   Text="Роль" 
                   ComboBoxWidth="200"
                   Margin="0,0,0,20"
                   ItemsSource="{Binding Roles}"/>
                <combobox:ComboBox x:Name="StatusComboBox" 
                   Text="Статус" 
                   Margin="0,0,0,20"
                   ComboBoxWidth="200"
                   ItemsSource="{Binding Status}" />
            </StackPanel>

            <!-- Правая колонка: Договор + ФИО -->
            <StackPanel Spacing="5">
                <!-- Трудовой договор и + в одной строке -->
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left"  Margin="0,0,0,20">
                    <TextBlock Text="Трудовой договор"
                               FontSize="20"
                               FontWeight="Normal"
                               Foreground="#194E84"/>
                    <TextBlock Text="+"
                               FontSize="20"
                               FontWeight="Normal"
                               Foreground="#194E84"/>
                    <Path Data="M21 15V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V15 M7 10L12 15L17 10 M12 15V3" 
                          Stroke="#194E84" 
                          StrokeThickness="2"
                          Width="12" 
                          Height="12"
                          Stretch="Uniform" Cursor="Hand"/>
                </StackPanel>
                
                <!-- Поля под договором -->
                <input:Input x:Name="NameInput" Text="Фамилия" InputWidth="200"/>
                <input:Input x:Name="SurnameInput" Text="Имя" InputWidth="200"/>
                <input:Input x:Name="PatronymicInput" Text="Отчество" InputWidth="200"/>
            </StackPanel>
        </StackPanel>
        
        <button:Button Text="Сохранить"
            HorizontalAlignment="Stretch"/> 
    </StackPanel>
</UserControl>