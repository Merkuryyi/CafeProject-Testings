<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CafeApp.Controls.FormInput"
             xmlns:button="clr-namespace:CafeApp.Controls.Components.Button"
             xmlns:input="clr-namespace:CafeApp.Controls.Components.Input"
             xmlns:combobox="clr-namespace:CafeApp.Controls.Components.ComboBox"
             Width="400"
             x:Name="root">
    
    <StackPanel Spacing="15">
        <TextBlock x:Name="TitleTextBlock" Text="{Binding #root.Title}"
            FontSize="24"
            FontWeight="Bold"
            Foreground="#194E84"
            HorizontalAlignment="Center"/>

        <StackPanel Spacing="5">
            <input:Input x:Name="UsernameInput" Text="Логин" InputWidth="400"/>
            <input:Input x:Name="PasswordInput" Text="Пароль" IsPassword="True" InputWidth="400"/>
        </StackPanel>

        <button:Button x:Name="LoginButton"
            Text="Далее"
            HorizontalAlignment="Stretch"
            Click="LoginButton_Click"/> 
    </StackPanel>
</UserControl>