<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CafeApp.Controls.Components.Button.Button"
             x:Name="root"
             Width="400"
             Height="45">
    
    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#AEC8D9"/>
            <Setter Property="Foreground" Value="#194E84"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#8BAEC9"/>
            <Setter Property="Foreground" Value="#194E84"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#8BAEC9"/>
            <Setter Property="Foreground" Value="#194E84"/>
        </Style>
    </UserControl.Styles>

    <Button x:Name="MainButton" Content="{Binding #root.Text}"/>

</UserControl>