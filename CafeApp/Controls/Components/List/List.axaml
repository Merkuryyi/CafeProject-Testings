<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CafeApp.Controls.Components.List.List"
             x:Name="root">
   
    <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="25" HorizontalAlignment="Left">
            <TextBlock Text="{Binding #root.Title}"
                       FontSize="24"
                       Foreground="#194E84"
                       FontWeight="Bold"/>
            <TextBlock Text="+" x:Name="AddOrder"
                       FontSize="20"
                       FontWeight="Normal"
                       Foreground="#194E84"
                       Cursor="Hand" />
        </StackPanel>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      MaxHeight="{Binding #root.ListHeight}">
            <ItemsControl ItemsSource="{Binding #root.Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15,10" Margin="0,5">
                            <TextBlock Text="{Binding}"
                                       FontSize="20"
                                       Foreground="#194E84" 
                                       Cursor="Hand"
                                       PointerPressed="OnItemPointerPressed"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</UserControl>