<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:combobox="clr-namespace:CafeApp.Controls.Components.ComboBox"
             xmlns:input="clr-namespace:CafeApp.Controls.Components.Input"
             xmlns:controls="clr-namespace:CafeApp.Controls"
             xmlns:button="clr-namespace:CafeApp.Controls.Components.Button"
             x:Class="CafeApp.Controls.EditOrder"
             x:Name="root">
    
    <StackPanel Spacing="30">
        <Border Padding="15">
            <StackPanel Spacing="15">
                <TextBlock Text="Заказ"
                           FontSize="20"
                           Foreground="#194E84"
                           FontWeight="Bold"/>
                
                <StackPanel Orientation="Horizontal" Spacing="25" HorizontalAlignment="Left">
                    <combobox:ComboBox x:Name="StatusComboBox" 
                               Text="Статус" 
                               ComboBoxWidth="200"/>  
                    <StackPanel Spacing="5">
                        <TextBlock Text="Официант"
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="WaiterTextBlock"
                                   Text="Иван Иванов"
                                   FontSize="14"
                                   Foreground="#194E84"/>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Столик" 
                                   FontSize="14"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="TableTextBlock"
                                   Text="5"
                                   FontSize="14"
                                   Foreground="#194E84"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Padding="15">
            <StackPanel Spacing="15">
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="Меню"
                               FontSize="20"
                               Foreground="#194E84"
                               FontWeight="Bold"/>
                </StackPanel>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                    <!-- ИСПРАВЛЕНО: StackPanel вместо ItemsControl с DataTemplate -->
                    <StackPanel x:Name="MenuItemsPanel" Spacing="10">
                        <!-- Элементы будут добавляться через код -->
                    </StackPanel>
                </ScrollViewer>
                
                <Border Background="#E6F2FF" Padding="10" CornerRadius="5" 
                        HorizontalAlignment="Right" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Общая сумма:"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#194E84"/>
                        <TextBlock x:Name="TotalAmountText"
                                   Text="0 руб."
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#194E84"/>
                    </StackPanel>
                </Border>
                
                <button:Button x:Name="SaveButton" Text="Сохранить"
                               HorizontalAlignment="Stretch"  
                               Click="SaveButton_Click"/> 
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>